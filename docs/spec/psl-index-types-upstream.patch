+    it('accepts extension index types from ContractSourceContext composedExtensionPackRefs', async () => {
+      const tempDir = await mkdtemp(join(tmpdir(), 'psl-provider-'));
+      tempDirs.push(tempDir);
+      const schemaPath = join(tempDir, 'schema.prisma');
+      await writeFile(
+        schemaPath,
+        `model Doc {
+  id Int @id
+  body String
+  @@index([body], type: "bm25", options: { key_field: "id" })
+}
+`,
+        'utf-8',
+      );
+
+      const indexExtensionPack = {
+        kind: 'extension',
+        id: 'test-index-pack',
+        familyId: 'sql',
+        targetId: 'postgres',
+        version: '0.0.1',
+        indexTypes: defineIndexTypes().add('bm25', {
+          options: type({ key_field: 'string' }),
+        }),
+      } as const;
+
+      process.chdir(tempDir);
+      const contract = prismaContract('./schema.prisma', baseOptions);
