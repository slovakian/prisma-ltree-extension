{
  "name": "prisma-ltree-family-tree",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down --volumes",
    "emit": "prisma-next contract emit",
    "db:plan": "prisma-next migration plan",
    "db:init": "prisma-next db init",
    "db:drop": "tsx scripts/drop-db.ts",
    "seed": "tsx scripts/seed.ts",
    "setup": "pnpm db:up && pnpm emit && pnpm db:plan && pnpm db:init && pnpm seed",
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@prisma-next/adapter-postgres": "0.14.0",
    "@prisma-next/contract": "0.14.0",
    "@prisma-next/driver-postgres": "0.14.0",
    "@prisma-next/family-sql": "0.14.0",
    "@prisma-next/postgres": "0.14.0",
    "@prisma-next/sql-builder": "0.14.0",
    "@prisma-next/sql-contract": "0.14.0",
    "@prisma-next/sql-contract-psl": "0.14.0",
    "@prisma-next/sql-contract-ts": "0.14.0",
    "@prisma-next/sql-relational-core": "0.14.0",
    "@prisma-next/sql-runtime": "0.14.0",
    "@prisma-next/target-postgres": "0.14.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "lucide-react": "^1.21.0",
    "pg": "^8.13.1",
    "prisma-ltree": "^0.2.1",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "0.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0"
}
