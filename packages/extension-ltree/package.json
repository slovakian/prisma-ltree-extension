{
  "name": "prisma-ltree",
  "version": "0.1.0",
  "description": "Prisma Next extension pack for PostgreSQL's ltree hierarchical tree data type.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/slovakian/prisma-ltree.git",
    "directory": "packages/extension-ltree"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./codec-types": "./dist/codec-types.mjs",
    "./column-types": "./dist/column-types.mjs",
    "./control": "./dist/control.mjs",
    "./operation-types": "./dist/operation-types.mjs",
    "./pack": "./dist/pack.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "build:contract-space": "prisma-next contract emit",
    "check-pins": "prisma-next-check-pins",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@prisma-next/contract": "0.14.0",
    "@prisma-next/contract-authoring": "0.14.0",
    "@prisma-next/family-sql": "0.14.0",
    "@prisma-next/framework-components": "0.14.0",
    "@prisma-next/migration-tools": "0.14.0",
    "@prisma-next/sql-contract": "0.14.0",
    "@prisma-next/sql-operations": "0.14.0",
    "@prisma-next/sql-relational-core": "0.14.0",
    "@prisma-next/sql-runtime": "0.14.0",
    "@prisma-next/sql-schema-ir": "0.14.0",
    "@standard-schema/spec": "^1.1.0",
    "arktype": "^2.2.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:",
    "@prisma-next/adapter-postgres": "0.14.0",
    "@prisma-next/cli": "0.14.0",
    "@prisma-next/extension-author-tools": "0.14.0",
    "@prisma-next/operations": "0.14.0",
    "@prisma-next/postgres": "0.14.0",
    "@prisma-next/sql-contract-ts": "0.14.0",
    "@prisma-next/target-postgres": "0.14.0",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "@prisma-next/adapter-postgres": "0.14.0",
    "typescript": ">=5.9"
  },
  "peerDependenciesMeta": {
    "@prisma-next/adapter-postgres": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  },
  "prismaNext": {
    "family": "sql",
    "dialects": [
      "postgres"
    ],
    "type": "extension-pack"
  }
}
